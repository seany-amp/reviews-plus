diff --git a/staging/src/k8s.io/apimachinery/pkg/api/validate/dependentrequired.go b/staging/src/k8s.io/apimachinery/pkg/api/validate/dependentrequired.go
--- a/staging/src/k8s.io/apimachinery/pkg/api/validate/dependentrequired.go
+++ b/staging/src/k8s.io/apimachinery/pkg/api/validate/dependentrequired.go
@@ -0,0 +1,54 @@
+/*
