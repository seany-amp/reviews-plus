+	st.Value(&Struct{Trigger: ptr.To("t")}).
+		OldValue(&Struct{Trigger: ptr.To("old")}).
+		ExpectValid()
+
+	// Newly cleared dependent → fire.
+	st.Value(&Struct{Trigger: ptr.To("t")}).
+		OldValue(&Struct{Trigger: ptr.To("t"), Dependent: ptr.To("d")}).
+		ExpectMatches(
+			field.ErrorMatcher{}.ByType().ByField().ByOrigin(),
