+fn hmac_sign<M: hmac::Mac + hmac::digest::KeyInit>(
+  key: &[u8],
+  data: &[u8],
+) -> Result<Vec<u8>, CryptoError> {
+  let mut mac = <M as hmac::Mac>::new_from_slice(key)
+    .map_err(|_| CryptoError::InvalidKeyLength)?;
+  mac.update(data);
+  Ok(mac.finalize().into_bytes().to_vec())
+}
